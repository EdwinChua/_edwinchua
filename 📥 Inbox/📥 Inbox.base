filters:
  and:
    - note["base"] == link("📥 Inbox.base")
properties:
  file.name:
    displayName: Name
  Notes:
    displayName: Notes
  Tags:
    displayName: Tags
  Created:
    displayName: Created
  Status:
    displayName: Status
  Area:
    displayName: Area
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Notes
      - Tags
      - Created
      - Status
      - Area
